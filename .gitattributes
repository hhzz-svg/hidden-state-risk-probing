# Keep reproducibility files stable across Windows/macOS/Linux
.gitattributes text eol=lf
.gitignore text eol=lf
* text=auto

*.py text eol=lf
*.mjs text eol=lf
*.md text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.bat text eol=crlf

*.png binary
*.xlsx binary
